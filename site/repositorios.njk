---
layout: base.njk
title: Repositorios
permalink: "/repositorios/index.html"
---
{% if reposEditions.length %}
  {% set ed = reposEditions[0] %}
  {% set repos = ed.repos %}
  {% set fecha = ed.date %}
  {% include "repos-lista.njk" %}

  <nav class="edicion-nav" aria-label="Navegación entre días de repositorios">
    {% if ed.reposOlderPath %}
      <a href="{{ ed.reposOlderPath | url }}">Día anterior</a>
    {% else %}<span></span>{% endif %}
    <a href="{{ '/repositorios/archivo/' | url }}">Todo el archivo</a>
    <span></span>
  </nav>
{% else %}
  <p class="empty">Aún no hay repositorios hot publicados. Vuelve mañana por la mañana.</p>
{% endif %}
