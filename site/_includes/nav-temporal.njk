{# Barra de navegación secuencial de una sección (día anterior / siguiente).
   El salto a una fecha concreta se hace con el calendario de arriba.
   Igual en noticias y repos: solo cambian los destinos. Espera olderPath, newerPath. #}
<nav class="edicion-nav" aria-label="Navegación entre días">
  {% if olderPath %}
    <a class="edicion-nav__flecha" href="{{ olderPath | url }}">← Anterior</a>
  {% else %}<span class="edicion-nav__flecha"></span>{% endif %}
  {% if newerPath %}
    <a class="edicion-nav__flecha" href="{{ newerPath | url }}">Siguiente →</a>
  {% else %}<span class="edicion-nav__flecha"></span>{% endif %}
</nav>
