{# Botón desplegable con el calendario de fechas disponibles. Espera `fechas`
   (lista con `.date`), `fechaAttr` (atributo de ruta) y `fechaActual`. #}
{% if fechas and fechas.length %}
<div class="cal-menu-wrap">
  <details class="cal-menu">
    <summary class="cal-menu__boton">Calendario <span class="cal-menu__chevron" aria-hidden="true">▾</span></summary>
    <div class="cal-menu__panel">
      <div class="calendario" data-actual="{{ fechaActual }}" aria-label="Calendario de ediciones disponibles">
        <script type="application/json" class="calendario__datos">[{% for e in fechas %}{"d":"{{ e.date }}","u":"{{ e[fechaAttr] | url }}"}{{ "," if not loop.last }}{% endfor %}]</script>
      </div>
    </div>
  </details>
</div>
{% endif %}
