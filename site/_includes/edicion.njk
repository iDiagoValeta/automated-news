{% macro share(social) %}
  {% if social %}
  <div class="share">
    <button class="share__btn" type="button" aria-label="Copiar para X" data-copy="{{ social.x }}">
      <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    </button>
    <button class="share__btn" type="button" aria-label="Copiar para LinkedIn" data-copy="{{ social.linkedin }}">
      <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
    </button>
    <span class="share__ok" role="status">Copiado</span>
  </div>
  {% endif %}
{% endmacro %}

{% set lead = edition.items[0] %}
<article class="edicion">
  <div class="dateline">
    <span class="dateline__fecha">{{ edition.date | fechaLarga }}</span>
    <span class="dateline__num">Edición número {{ edition.numero }}</span>
  </div>

  {% if lead %}
    <article class="lead">
      <div class="item-head">
        <span class="kicker">{{ lead.category }}</span>
        {{ share(lead.social) }}
      </div>
      <h2 class="lead__title">
        <a href="{{ lead.url }}" target="_blank" rel="noopener">{{ lead.title }}</a>
      </h2>
      <p class="lead__summary">{{ lead.summary }}</p>
      <p class="why"><span class="why__label">Por qué importa</span>{{ lead.why_it_matters }}</p>
      <p class="source">
        <a href="{{ lead.url }}" target="_blank" rel="noopener">{{ lead.source }}</a>
      </p>
    </article>
  {% endif %}

  {% if edition.items.length > 1 %}
    <div class="stories">
      {% for item in edition.items %}
        {% if loop.index0 > 0 %}
        <article class="story">
          <div class="item-head">
            <span class="kicker">{{ item.category }}</span>
            {{ share(item.social) }}
          </div>
          <h3 class="story__title">
            <a href="{{ item.url }}" target="_blank" rel="noopener">{{ item.title }}</a>
          </h3>
          <p class="story__summary">{{ item.summary }}</p>
          <p class="why"><span class="why__label">Por qué importa</span>{{ item.why_it_matters }}</p>
          <p class="source">
            <a href="{{ item.url }}" target="_blank" rel="noopener">{{ item.source }}</a>
          </p>
        </article>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}

  {% if edition.repos and edition.repos.length %}
    <section class="repos" aria-labelledby="repos-titulo">
      <h2 class="repos__title" id="repos-titulo">Repositorios hot del día</h2>
      <div class="repos__grid">
        {% for repo in edition.repos %}
        <article class="repo">
          <h3 class="repo__name">
            <a href="{{ repo.url }}" target="_blank" rel="noopener">{{ repo.name }}</a>
          </h3>
          <p class="repo__desc">{{ repo.description }}</p>
          <p class="repo__meta">
            {% if repo.language %}<span class="repo__lang">{{ repo.language }}</span>{% endif %}
            {% if repo.stars %}<span class="repo__stars">{{ repo.stars }} ★</span>{% endif %}
          </p>
        </article>
        {% endfor %}
      </div>
    </section>
  {% endif %}

  <nav class="edicion-nav" aria-label="Navegación entre ediciones">
    {% if edition.olderPath %}
      <a href="{{ edition.olderPath | url }}">Edición anterior</a>
    {% else %}<span></span>{% endif %}
    <a href="{{ '/archivo/' | url }}">Todas las ediciones</a>
    {% if edition.newerPath %}
      <a href="{{ edition.newerPath | url }}">Edición siguiente</a>
    {% else %}<span></span>{% endif %}
  </nav>
</article>
