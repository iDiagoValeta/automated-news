{% from "share.njk" import share %}

{% set lead = edition.items[0] %}
{% set fechas = editions %}
{% set fechaAttr = "path" %}
{% set fechaActual = edition.date %}
{% include "calendario.njk" %}
<article class="edicion">
  {% if lead %}
    <article class="lead">
      <div class="item-head">
        <span class="kicker">{{ lead.category }}</span>
        {{ share(lead.social) }}
      </div>
      <h2 class="lead__title">
        <a href="{{ lead.url }}" target="_blank" rel="noopener">{{ lead.title }}</a>
      </h2>
      <p class="lead__summary">{{ lead.summary }}</p>
      <p class="why"><span class="why__label">Por qué importa</span>{{ lead.why_it_matters }}</p>
      <p class="source">
        <a href="{{ lead.url }}" target="_blank" rel="noopener">{{ lead.source }}</a>
      </p>
    </article>
  {% endif %}

  {% if edition.items.length > 1 %}
    <div class="stories">
      {% for item in edition.items %}
        {% if loop.index0 > 0 %}
        <article class="story">
          <div class="item-head">
            <span class="kicker">{{ item.category }}</span>
            {{ share(item.social) }}
          </div>
          <h3 class="story__title">
            <a href="{{ item.url }}" target="_blank" rel="noopener">{{ item.title }}</a>
          </h3>
          <p class="story__summary">{{ item.summary }}</p>
          <p class="why"><span class="why__label">Por qué importa</span>{{ item.why_it_matters }}</p>
          <p class="source">
            <a href="{{ item.url }}" target="_blank" rel="noopener">{{ item.source }}</a>
          </p>
        </article>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}

  {% set olderPath = edition.olderPath %}
  {% set newerPath = edition.newerPath %}
  {% include "nav-temporal.njk" %}
</article>
