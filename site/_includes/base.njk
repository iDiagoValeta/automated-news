<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title %}{{ title }}, {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
    <meta name="description" content="{{ site.descripcion }}" />
    <link rel="stylesheet" href="{{ '/css/diario.css' | url }}" />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%23181613'/%3E%3Ctext x='7' y='23' font-family='monospace' font-size='18' fill='%23f2b705'%3E%3E_%3C/text%3E%3C/svg%3E"
    />
  </head>
  <body>
    <a class="skip" href="#contenido">Saltar al contenido</a>

    <header class="masthead">
      <a class="masthead__name" href="{{ '/' | url }}">{{ site.title }}</a>
      <p class="masthead__tagline">{{ site.tagline }}</p>
      <nav class="masthead__nav" aria-label="Secciones">
        <a href="{{ '/' | url }}">Portada</a>
        <a href="{{ '/archivo/' | url }}">Archivo</a>
      </nav>
    </header>

    <main id="contenido" class="content">{{ content | safe }}</main>

    <script src="{{ '/js/compartir.js' | url }}" defer></script>

    <footer class="pie">
      <a href="{{ '/' | url }}">{{ site.title }}</a>
      <a href="{{ site.repo }}" rel="noopener">Código fuente</a>
    </footer>
  </body>
</html>
