---
pagination:
  data: reposEditions
  size: 1
  alias: ed
layout: base.njk
permalink: "{{ ed.reposPath }}"
eleventyComputed:
  title: "Repositorios {{ ed.date | fechaCorta }} {{ ed.year }}"
---
{% set repos = ed.repos %}
{% set fecha = ed.date %}
{% include "repos-lista.njk" %}

<nav class="edicion-nav" aria-label="Navegación entre días de repositorios">
  {% if ed.reposOlderPath %}
    <a href="{{ ed.reposOlderPath | url }}">Día anterior</a>
  {% else %}<span></span>{% endif %}
  <a href="{{ '/repositorios/archivo/' | url }}">Todo el archivo</a>
  {% if ed.reposNewerPath %}
    <a href="{{ ed.reposNewerPath | url }}">Día siguiente</a>
  {% else %}<span></span>{% endif %}
</nav>
